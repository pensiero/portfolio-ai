# Copy to .env and adjust. Never commit the real .env (it's git-ignored).

# PORT=8787

# LLM provider — 'ollama' (local default) or 'opencode' (hosted, OpenAI-compatible).
# Swapping is just this var plus the provider's settings below; no route changes.
# LLM_PROVIDER=ollama

# --- Local: Ollama ---
# OLLAMA_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=gemma4:12b-mlx

# --- Hosted: OpenCode Go (Zen) ---
# Get the key at https://opencode.ai/auth. One key unlocks the whole Zen catalog.
# OPENCODE_API_KEY=sk-...
# OPENCODE_BASE_URL=https://opencode.ai/zen/go/v1
# OPENCODE_MODEL=deepseek-v4-flash   # or deepseek-v4-pro, kimi-k2.6, qwen3.7-plus, ...

# Path to the private biography the AI answers from (git-ignored, never served).
# PRIVATE_DOC_PATH=content/private-context.md
